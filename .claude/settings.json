{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__tmux__*",
      "Bash(agent-browser:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git rev-parse:*)",
      "Bash(git show:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git config --get:*)",
      "Bash(git describe:*)",
      "Bash(git merge-base:*)",
      "Bash(git blame:*)",
      "Bash(git reflog:*)",
      "Bash(pbcopy:*)",
      "Bash(fd:*)",
      "Bash(rg:*)",
      "Bash(cat:*)",
      "Bash(ls:*)"
    ],
    "defaultMode": "default"
  },
  "model": "claude-opus-4-6",
  "disabledMcpjsonServers": [
    "chrome-devtools",
    "sentry",
    "storybook",
    "figma-desktop"
  ],
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0
  },
  "enabledPlugins": {
    "frontend-design@claude-code-plugins": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {},
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true
}
