#!/bin/bash

if [ ! -d .git ]; then
  echo -e "Error: This script must be run from the root of a git repository."
  exit 1
fi

# Start a tmux session in each numbered worktree dir of cbdev repo
for path in ./*; do
  if [ -d "$path" ]; then
    wt=$(basename "$path")
    if tmux has-session -t="$wt" 2>/dev/null; then
      continue
    fi
    tmux new-session -d -s "$wt" -c "$path"
    tmux split-window -h -t "$wt:" -c "$path"
    tmux select-layout -t "$wt:" even-horizontal
    tmux select-pane -t "$wt:" -L
  fi
done

tmux set -g status on

if [ -n "$TMUX" ]; then
  echo "Sessions appended (already inside tmux). Use prefix+s to switch."
else
  tmux attach
fi
